{
  "name": "KeloShell",
  "version": "0.0.1",
  "description": "Private workout logging companion for a coach-managed spreadsheet",
  "main": "index.js",
  "scripts": {
    "dev-server": "vite --open",
    "dev": "npm run build && wrangler pages dev dist",
    "dev:ui": "vite",
    "dev-task": "vite",
    "deploy": "npm run build && wrangler pages deploy dist",
    "build": "tsc && tsc -p tsconfig.worker.json && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "npm run dev",
    "start-remote": "vite --host"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "lit": "^3.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260628.1",
    "typescript": "^5.6.3",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.105.0"
  },
  "prettier": {
    "tabWidth": 2,
    "useTabs": false,
    "semi": true,
    "singleQuote": true,
    "quoteProps": "consistent",
    "trailingComma": "es5",
    "endOfLine": "crlf",
    "bracketSpacing": true
  }
}
