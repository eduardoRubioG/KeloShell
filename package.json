{
  "name": "KeloShell",
  "version": "0.0.1",
  "description": "Private workout logging companion for a coach-managed spreadsheet",
  "main": "index.js",
  "scripts": {
    "dev-server": "vite --open",
    "dev": "npm run build && wrangler pages dev dist",
    "dev:ui": "vite",
    "dev-task": "vite",
    "deploy": "npm run build && wrangler pages deploy dist",
    "build": "tsc --noEmit && tsc -p tsconfig.worker.json && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "npm run dev",
    "start-remote": "vite --host"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260628.1",
    "@fontsource-variable/archivo": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.18",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.6.3",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.105.0"
  },
  "prettier": {
    "tabWidth": 2,
    "useTabs": false,
    "semi": true,
    "singleQuote": true,
    "quoteProps": "consistent",
    "trailingComma": "es5",
    "endOfLine": "crlf",
    "bracketSpacing": true
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.16",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
